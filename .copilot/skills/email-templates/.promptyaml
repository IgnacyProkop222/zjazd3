name: email-templates
description: Skill dla tworzenia i testowania szablonów emaili
topics:
  - templates
  - email
  - html
  - text
  - testing
applyTo:
  - path: "**/templates/**"
  - path: "**/mailer/**"
  - path: "**/tests/**"
languageDetection:
  preferredLanguage: python
  patterns:
    - "template"
    - "email"
    - "jinja"
